# EventRegistrations.jl Credentials Configuration
# Copy this file to credentials.toml and fill in your actual credentials
# WARNING: Never commit credentials.toml to version control!

[email]
# POP3 email download configuration (optional)
server = "mail.example.com"
username = "events@example.com"
password = "your-pop3-password"
port = 995

[smtp]
# SMTP email sending configuration (optional)
server = "smtp.example.com"
port = 587
username = "events@example.com"
password = "your-smtp-password"
from_address = "no-reply@example.com"
from_name = "Event Registration System"
additional_info = "For questions, contact events@example.com"
bank_details = ""
# redirect_to = "test@example.com"  # Optional: redirect ALL emails to this address for testing

[bank]
# Bank account details for QR code generation (optional)
account_name = "Your Organization Name"
iban = "DE89 3704 0044 0532 0130 00"
bic = "COBADEFFXXX"
bank_name = "Your Bank Name"
enable_qr = true
remittance = ""

[webdav]
# WebDAV upload configuration for ownCloud/Nextcloud (optional)
# Uploads exported files (.xlsx, .csv, .pdf) to a shared folder
url = "https://cloud.example.com/remote.php/webdav"
username = "your-webdav-username"
password = "your-webdav-password"
remote_path = "share/"  # Base path for uploads (default: "" for root)

# Notes:
# - remote_path should end with "/" for proper path construction
# - Uploaded files keep their original names (e.g., payment_status_PWE_2026_01.csv)
# - Files are uploaded only when --upload flag is used
# - Existing files at the remote path will be overwritten
